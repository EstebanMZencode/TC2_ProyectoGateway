{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            "ruta-productos": {
                "ClusterId": "cluster-catalogo",
                "Match": {
                    "Path": "/api/productos/{**catch-all}"
                },
                "Transforms": [
                    {
                        "RequestHeader": "X-Gateway-Origen",
                        "Set": "ServicioGateway"
                    },
                    {
                        "RequestHeader": "X-Servicio-Destino",
                        "Set": "Catalogo"
                    }
                ]
            },
            "ruta-clientes": {
                "ClusterId": "cluster-cliente",
                "Match": {
                    "Path": "/api/clientes/{**catch-all}"
                },
                "Transforms": [
                    {
                        "RequestHeader": "X-Gateway-Origen",
                        "Set": "ServicioGateway"
                    },
                    {
                        "RequestHeader": "X-Servicio-Destino",
                        "Set": "Cliente"
                    }
                ]
            },
            "ruta-ordenes": {
                "ClusterId": "cluster-ordencompra",
                "Match": {
                    "Path": "/api/ordenes/{**catch-all}"
                },
                "Transforms": [
                    {
                        "RequestHeader": "X-Gateway-Origen",
                        "Set": "ServicioGateway"
                    },
                    {
                        "RequestHeader": "X-Servicio-Destino",
                        "Set": "OrdenCompra"
                    }
                ]
            }
        },
        "Clusters": {
            "cluster-catalogo": {
                "Destinations": {
                    "destino1": {
                        "Address": "https://tiusr23pl.cuc-carrera-ti.ac.cr/MicroServicioCatalogo/"
                    }
                }
            },
            "cluster-cliente": {
                "Destinations": {
                    "destino1": {
                        "Address": "https://tiusr23pl.cuc-carrera-ti.ac.cr/MicroServicioCliente/"
                    }
                }
            },
            "cluster-ordencompra": {
                "Destinations": {
                    "destino1": {
                        "Address": "https://tiusr23pl.cuc-carrera-ti.ac.cr/MicroServicioOrdenCompra/"
                    }
                }
            }
        }
    }
}